# LinkRevive Environment Variables
# Copy to .env and fill in your values

# ── Database ──────────────────────────────
DATABASE_URL=postgresql://linkrevive:linkrevive_dev@localhost:5432/linkrevive

# ── Redis ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────
# Generate with: openssl rand -hex 32
API_SECRET_KEY=replace-with-a-random-32-character-string-minimum

# Allow CORS from frontend origin(s), comma-separated
ALLOWED_ORIGINS=http://localhost:3000

# ── Anthropic ─────────────────────────────
# Optional - if not provided, will fallback to Ollama
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Local AI (Ollama) ─────────────────────
# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
# Model to use (default: llama3.1:8b)
# Popular options: llama3.1:8b, llama3.1:70b, codellama:7b, mistral:7b
OLLAMA_MODEL=llama3.1:8b

# ── Google Custom Search (optional) ───────
# Get from: https://programmablesearchengine.google.com/
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=

# ── GitHub (optional) ─────────────────────
# Increases rate limit from 60 to 5000 req/hr
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# ── Feature flags ─────────────────────────
ENABLE_AI_EXPLANATIONS=true

# Max links to check per bulk scan (abuse prevention)
MAX_BULK_LINKS=100

# ── Cache TTLs (seconds) ──────────────────
CACHE_TTL_LINK_RESULT=3600    # 1 hour
CACHE_TTL_ARCHIVE=86400        # 24 hours
CACHE_TTL_ALTERNATIVES=43200   # 12 hours

# ── Server ────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Frontend (Next.js) ────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
