{
  "name": "linkrevive-backend",
  "version": "1.0.0",
  "description": "LinkRevive API server and workers",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/index.ts",
    "test": "jest --testPathPattern='__tests__'",
    "test:integration": "jest --testPathPattern='integration'",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx src/db/seed.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.15.0",
    "bullmq": "^5.8.0",
    "cheerio": "^1.0.0",
    "got": "^14.4.1",
    "ioredis": "^5.4.1",
    "fastify": "^4.28.1",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "prisma": "^5.15.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFilesAfterEach": ["<rootDir>/src/__tests__/setup.ts"]
  }
}
